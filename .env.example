# Copy this file to .env and fill in real values. Never commit .env.

# Required. OpenAI API key used by the four LLM agents (clarification,
# priority, execution, report). If unset, all agents fall back to their
# deterministic rule-based logic automatically.
OPENAI_API_KEY=

# Required in production. Signs and verifies JWT access tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# There is no default — the app refuses to start without this set.
SECRET_KEY=

# development | production
# In production, the auth cookie is only set with the Secure flag
# (HTTPS-only). Must be "production" for any real deployment.
ENVIRONMENT=development

# Comma-separated list of origins allowed to call the API via CORS.
# Example for local dev: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Directory where the Chroma vector store persists its data on disk.
CHROMA_PERSIST_DIR=./chroma_data

# Base URL of the React app, used to build the links sent in invite and
# password-reset emails (e.g. https://awla.example.com).
FRONTEND_URL=http://localhost:5173

# SMTP settings for invite/password-reset emails. If SMTP_HOST is unset,
# emails are logged instead of sent -- fine for local dev, not for
# production. SMTP_USER/SMTP_PASSWORD are optional (omit for an
# unauthenticated relay).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Awla <no-reply@awla.local>
